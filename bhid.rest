############################################################
### USERS
############################################################

### Get All Users

GET {{baseUrl}}/users

###

### Get User by ID

GET {{baseUrl}}/users/6a63ac9aa9d54fa4766ae6e0

###

### Create User

POST {{baseUrl}}/users
Content-Type: application/json

{
    "first_name": "David",
    "last_name": "Caleb",
    "username": "davidcaleb",
    "email": "david@example.com",
    "password": "Password123!"
}

###

### Update User

PUT {{baseUrl}}/users/6a63ac9aa9d54fa4766ae6e0
Content-Type: application/json

{
    "first_name": "David Updated"
}

###

### Delete User

DELETE {{baseUrl}}/users/PUT_USER_ID_HERE

###

